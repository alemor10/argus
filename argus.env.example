# Argus secrets + config — TEMPLATE (safe to commit; contains no real values).
#
# Copy to your machine, fill in, and deploy with scripts/deploy.sh:
#     mkdir -p ~/.config/argus
#     cp argus.env.example ~/.config/argus/argus.env
#     $EDITOR ~/.config/argus/argus.env      # fill in the values below
#     ./scripts/deploy.sh                     # pushes it to the box over SSH
#
# The real ~/.config/argus/argus.env NEVER goes in git (this repo is public).
# Every ACTIVE line MUST start with `export`, or the value will not reach the
# `uv run argus` child process at run time.

# --- Delivery (at least one recommended) -----------------------------------
# Discord webhook — Channel settings → Integrations → Webhooks → New → Copy URL
export ARGUS_DISCORD_WEBHOOK="https://discord.com/api/webhooks/XXXX/YYYY"

# Attach the PDF report (1 = on, 0 = markdown only)
export ARGUS_PDF=1

# --- Cross-check sources (both free; each sharpens data quality) ------------
# SEC EDGAR fundamentals cross-check — no signup, just a contact email SEC can
# reach you at. Enables cross-checking Yahoo's margins/debt against filings.
export ARGUS_CONTACT_EMAIL="you@example.com"

# Finnhub price cross-check — free key from https://finnhub.io. Corroborates
# Yahoo's price so quarantine blame can localize to the bad number.
# export FINNHUB_API_KEY="your-key-here"

# --- Email digest delivery (optional; Gmail app password) ------------------
# export ARGUS_EMAIL_TO="you@example.com"
# export ARGUS_SMTP_USER="you@example.com"
# export ARGUS_SMTP_PASSWORD="app-password"
